views:
  - type: table
    name: 附件
    order:
      - file.name
      - tags
    sort:
      - property: file.name
        direction: ASC
      - property: tags
        direction: DESC
    summaries:
      formula.未命名: new summary
    columnSize:
      file.name: 225
  - type: table
    name: 笔记
    filters:
      and:
        - file.inFolder("数学/高等数学")
        - '!file.inFolder("数学/高等数学/_old")'
        - file.ext == "md"
